generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  avatar           String?
  city             String?
  rating           Float     @default(5.0)
  
  // Role: PASSENGER or DRIVER
  role             String    @default("PASSENGER")
  
  // Driver-specific fields
  isDriver         Boolean   @default(false)
  vehicleType      String?   // AUTO, MINI_CAB, SEDAN, SUV
  vehiclePlate     String?
  vehicleModel     String?
  isOnline         Boolean   @default(false)
  currentLat       Float?
  currentLng       Float?
  
  // Trust & Safety Pillar
  kycLevel         Int       @default(0)
  kycStatus        String    @default("UNVERIFIED") // UNVERIFIED, PENDING, VERIFIED, REJECTED
  kycDlUrl         String?
  kycRcUrl         String?
  kycInsuranceUrl  String?
  kycLivenessUrl   String?
  kycVehicleUrls   String[]
  gender           String?
  emergencyContact String?

  ridesCreated     Ride[]    @relation("DriverRides")
  bookings         Booking[]
  createdAt        DateTime  @default(now())
}

model Ride {
  id             String    @id @default(cuid())
  driverId       String
  driver         User      @relation("DriverRides", fields: [driverId], references: [id])
  
  fromAddress    String
  fromLat        Float
  fromLng        Float
  toAddress      String
  toLat          Float
  toLng          Float
  
  // PostGIS Geography for GIST indexing
  originGeom     Unsupported("geography(Point, 4326)")?
  destGeom       Unsupported("geography(Point, 4326)")?
  
  // Route Overlap (Pillar 1)
  polyline       String?
  routeGeom      Unsupported("geometry(LineString, 4326)")?

  departureTime  DateTime
  seatsAvailable Int
  price          Float
  
  // Vehicle & Fare
  vehicleType    String    @default("MINI_CAB") // AUTO, MINI_CAB, SEDAN, SUV
  baseFare       Float     @default(0)
  farePerKm      Float     @default(15)
  distanceKm     Float     @default(0)
  estimatedMinutes Int     @default(0)
  
  status         String    @default("SEARCHING") // SEARCHING, DRIVER_ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  
  // UX Features
  meetupLat      Float?
  meetupLng      Float?
  isRecurring    Boolean   @default(false)
  recurringDays  String[]

  bookings       Booking[]
  createdAt      DateTime  @default(now())

  @@index([status, departureTime])
}

model Booking {
  id          String   @id @default(cuid())
  rideId      String
  passengerId String
  status            String   @default("PENDING") // PENDING, CONFIRMED, BOARDED, CANCELLED
  otp               String?
  
  // Match & Fare
  matchType         String   @default("EXACT") // EXACT, DEST_ON_ROUTE, SOURCE_ON_ROUTE
  seats             Int      @default(1)
  poolDiscount      Float    @default(0)
  finalFare         Float    @default(0)
  
  // Payment Integration
  razorpayOrderId   String?  @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  paymentStatus     String   @default("PENDING")

  ride              Ride     @relation(fields: [rideId], references: [id])
  passenger         User     @relation(fields: [passengerId], references: [id])
  createdAt   DateTime @default(now())
}